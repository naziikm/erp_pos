# POS ERP System - Environment Configuration
# Copy this file to .env and fill in your values

# MySQL Database
MYSQL_URL=mysql+pymysql://root:password@localhost:3306/pos_erp_system

# ERPNext Connection
ERP_BASE_URL=https://your-erp.example.com
ERP_API_KEY=your_api_key
ERP_API_SECRET=your_api_secret

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# License
LICENSE_HMAC_SECRET=change-this-to-a-random-license-secret

# Sync Intervals
STOCK_SYNC_INTERVAL_MINUTES=15
INVOICE_SYNC_INTERVAL_SECONDS=30
ERP_SYNC_INTERVAL_MINUTES=5

# ERP Client
ERP_REQUEST_TIMEOUT_SECONDS=30
MAX_INVOICE_PUSH_ATTEMPTS=3

# Logging
LOG_LEVEL=INFO
